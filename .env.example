# Nova server defaults
HOST=0.0.0.0
PORT=4000

# Local app data root (SQLite DB, attachments, logs, agent homes)
# NOVA_APP_DATA_DIR=.nova-data

# Runtime mode
NOVA_RUNTIME_MODE=openclaw

# OpenClaw
OPENCLAW_PROFILE=apm
OPENCLAW_BINARY_PATH=openclaw
# OPENCLAW_CONFIG_PATH=
# OPENCLAW_STATE_DIR=
# OPENCLAW_GATEWAY_URL=
# OPENCLAW_GATEWAY_TOKEN=
# NOVA_ENABLE_OPENCLAW_SMOKE=false

# Anonymous install telemetry.
#   - Sends a small ping on startup and every 24h so the maintainer
#     knows how many people are running Nova. No personal data.
#   - See docs/operations/telemetry.md for exactly what gets sent.
#   - Set NOVA_TELEMETRY=0 to opt out.
#   - Set NOVA_TELEMETRY_ENDPOINT to redirect pings to your own collector.
# NOVA_TELEMETRY=1
# NOVA_TELEMETRY_ENDPOINT=

# Codex
CODEX_BINARY_PATH=codex
# CODEX_CONFIG_PATH=
# CODEX_STATE_DIR=
# CODEX_DEFAULT_MODEL=gpt-5.4

# Claude Code
CLAUDE_BINARY_PATH=claude
# CLAUDE_CONFIG_PATH=
# CLAUDE_STATE_DIR=
# CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6

# Optional Google auth for the web app
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional web overrides for split deployments or LAN development
# NOVA_WEB_HOST=127.0.0.1
# NOVA_WEB_PORT=3000
# NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000
# NOVA_BACKEND_URL=http://127.0.0.1:4010/api
# NEXT_PUBLIC_API_BASE_URL=/api/backend
# NOVA_DEV_LAN=1
# NOVA_DEV_LAN_IP=192.168.2.50
