{
  "name": "@nova/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.10",
    "@nova/shared": "workspace:*",
    "drizzle-orm": "^0.43.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.0.0"
  }
}
